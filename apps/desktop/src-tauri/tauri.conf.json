{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Plankton",
  "version": "0.1.12",
  "identifier": "com.openaquarium.plankton",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Plankton Approval Console",
        "width": 1440,
        "height": 840,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["plankton"]
      }
    }
  }
}
